# 复制为 .env 后按需修改。.env 不会进 git。

# ---- Gradio Hybrid Search 用的 embedding 服务（OpenAI 兼容 /embeddings）----
# 代码里已经写死了内网 qwen3-embedding 作为默认值，无需配置也能跑 hybrid。
# 想换其它 embedding 服务再显式覆盖；显式置空才会降级为 BM25-only。
# EMBEDDING_BASE_URL=http://mlp.paas.dc.servyou-it.com/qwen3-embedding/v1
# EMBEDDING_MODEL=qwen3-embedding
# EMBEDDING_API_KEY=

# ---- 反向代理前缀 ----
# 反向代理部署默认 /kh-lancedb；本机直连请改成空串。
# PROXY_ROOT_PATH=/kh-lancedb

# ---- 服务基础配置（详见 app/config.py::Settings）----
# API_KEY=
# STORE_DIR=./data
# HOST=0.0.0.0
# PORT=5000
# LOG_LEVEL=INFO
