# 复制为 .env 后按需修改。.env 不会进 git。

# ---- 服务端/Gradio 共用的 embedding 服务（OpenAI 兼容 /embeddings）----
# 用于：1) Gradio Hybrid Search 自动向量化；2) API 在缺失 vector/query_vector 时自动兜底。
# 代码里已写死内网 qwen3-embedding 默认值；想换其它 embedding 服务再显式覆盖。
# EMBEDDING_BASE_URL=http://mlp.paas.dc.servyou-it.com/qwen3-embedding/v1
# EMBEDDING_MODEL=qwen3-embedding
# EMBEDDING_API_KEY=
# EMBEDDING_TIMEOUT_SEC=10
# ENABLE_SERVER_EMBEDDING_FALLBACK=true

# ---- 反向代理前缀 ----
# 反向代理部署默认 /kh-lancedb；本机直连请改成空串。
# PROXY_ROOT_PATH=/kh-lancedb

# ---- 服务基础配置（详见 app/config.py::Settings）----
# API_KEY=
# 默认指向与 lancedb-server 同级的 ../resources（见 app/config.py）。
# STORE_DIR=../resources
# HOST=0.0.0.0
# PORT=5000
# LOG_LEVEL=INFO

# 建索引放后台异步执行：upsert 写完即返回，避免客户端 read timeout。默认开启；
# 设为 0 可恢复同步建索引（upsert 返回时索引已就绪，但响应更慢）。
# ENABLE_ASYNC_INDEXING=1

# 行数达到该阈值才建 IVF-PQ 向量索引；低于此值不建索引，向量检索仍可用（全表精确 KNN）。
# 默认 4096；小表可避免 KMeans 空簇告警与 PQ 量化误差。
# VECTOR_INDEX_MIN_ROWS=4096

# append 模式按 chunk_id 幂等 upsert：客户端重试 / 重复发送同一文档不会产生重复行。
# 默认开启；设为 0 可恢复旧的「无脑追加」语义（允许同 chunk_id 多行）。
# IDEMPOTENT_APPEND=1

# 全局反查 /v1/relations:lookup-dependents 的并行扫描线程上限。
# 默认 8；设为 1 可退回串行。表很多时可适当调大，但会增加 I/O 与 CPU 压力。
# 注意：仅在 ENABLE_RELATION_INDEX=0（或索引尚未覆盖全部 source）的扫描兜底路径下生效。
# LOOKUP_DEPENDENTS_MAX_WORKERS=8

# relation 反向索引（SQLite）：把 lookup-dependents 从“全库扫描”降为“点查”。
# 默认开启；upsert 成功后按 source 增量维护，索引文件为 STORE_DIR/_relation_index.sqlite3。
# 首次启用 / 历史数据会自动后台补建，也可手动 POST /v1/relations:reindex 预热。
# 设为 0 可关闭索引、始终走全表扫描（行为与旧版一致）。
# ENABLE_RELATION_INDEX=1
